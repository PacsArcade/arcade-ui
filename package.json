{
  "name": "@pacsarcade/arcade-ui",
  "version": "0.1.0",
  "description": "Pac's Arcade 8-bit crowdfunding UI kit — CRT-authentic components for campaign pages",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
